<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="SMITH"/>
  <meta name="theme-color" content="#0a0a0a"/>
  <title>SMITH</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

    :root {
      --bg: #0a0a0a;
      --surface: #131313;
      --surface2: #1a1a1a;
      --border: #242424;
      --text: #e8e8e8;
      --muted: #555;
      --d1: #E63946;
      --d2: #3A86FF;
      --d3: #06D6A0;
      --d4: #9B5DE5;
      --gold: #c8a96e;
      --gold-dim: #7a6340;
      --green: #52b788;
      --blue: #74b3ce;
      --font-display: 'Barlow Condensed', sans-serif;
      --font-body: 'Barlow', sans-serif;
      --safe-bottom: env(safe-area-inset-bottom, 0px);
      --safe-top: env(safe-area-inset-top, 0px);
      --nav-h: 60px;
    }

    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font-body); overflow: hidden; }

    /* ── APP SECTIONS ── */
    .app-section { display: none; flex-direction: column; height: calc(100vh - var(--nav-h) - var(--safe-bottom)); overflow: hidden; }
    .app-section.active { display: flex; }

    /* ── BOTTOM NAV ── */
    .main-nav {
      position: fixed; bottom: 0; left: 0; right: 0;
      height: calc(var(--nav-h) + var(--safe-bottom));
      padding-bottom: var(--safe-bottom);
      background: var(--surface);
      border-top: 1px solid var(--border);
      display: grid; grid-template-columns: repeat(2, 1fr);
      z-index: 1000;
    }
    .main-nav-item {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 3px; cursor: pointer; transition: opacity 0.15s;
    }
    .main-nav-item:active { opacity: 0.6; }
    .main-nav-icon { font-size: 22px; }
    .main-nav-label {
      font-family: var(--font-display); font-size: 10px; letter-spacing: 2px; color: var(--muted);
    }
    .main-nav-item.active .main-nav-label { color: var(--d1); }

    /* ══════════════════════════════════════════
       LIFT SECTION
    ══════════════════════════════════════════ */
    #lift { overflow-y: auto; -webkit-overflow-scrolling: touch; }

    /* Lift sub-screens */
    .lift-screen { display: none; }
    .lift-screen.active { display: block; }

    /* HOME */
    .lift-home { padding: calc(var(--safe-top) + 32px) 20px 20px; }
    .lift-eyebrow { font-family: var(--font-display); font-size: 11px; letter-spacing: 4px; color: var(--muted); margin-bottom: 4px; }
    .lift-title { font-family: var(--font-display); font-size: 48px; font-weight: 900; line-height: 0.95; color: var(--text); letter-spacing: -1px; }
    .lift-title span { color: var(--d1); }
    .lift-sub { font-size: 13px; color: var(--muted); margin-top: 8px; }
    .cycle-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 100px; padding: 7px 14px; margin-top: 16px;
    }
    .cycle-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--d1); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
    .cycle-text { font-family: var(--font-display); font-size: 13px; letter-spacing: 2px; }

    .day-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 20px; }
    .day-card {
      background: var(--surface); border-radius: 14px; padding: 18px 14px 14px;
      border: 1px solid var(--border); cursor: pointer;
      transition: transform 0.15s; position: relative; overflow: hidden;
    }
    .day-card:active { transform: scale(0.97); }
    .day-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); }
    .day-card-num { font-family: var(--font-display); font-size: 38px; font-weight: 900; color: var(--accent); opacity: 0.2; position: absolute; top: 8px; right: 12px; }
    .day-card-label { font-family: var(--font-display); font-size: 10px; letter-spacing: 3px; color: var(--muted); margin-bottom: 3px; }
    .day-card-title { font-family: var(--font-display); font-size: 16px; font-weight: 700; line-height: 1.2; }
    .day-card-day { font-size: 11px; color: var(--muted); margin-top: 6px; }
    .day-card-bar { margin-top: 10px; height: 3px; background: var(--border); border-radius: 99px; overflow: hidden; }
    .day-card-fill { height: 100%; border-radius: 99px; transition: width 0.4s; }
    .day-card-pct { font-size: 10px; color: var(--muted); margin-top: 4px; }

    .lift-footer { display: flex; gap: 8px; margin-top: 16px; padding-bottom: 20px; }
    .btn-ghost {
      flex: 1; padding: 13px; background: transparent;
      border: 1px solid var(--border); border-radius: 10px;
      color: var(--muted); font-family: var(--font-display);
      font-size: 12px; letter-spacing: 2px; cursor: pointer;
    }
    .btn-ghost:active { background: var(--surface); color: var(--text); }

    /* WORKOUT SCREEN */
    .workout-header {
      padding: calc(var(--safe-top) + 12px) 18px 0;
      background: var(--bg); position: sticky; top: 0; z-index: 50;
    }
    .workout-topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .btn-back {
      width: 34px; height: 34px; border-radius: 50%;
      border: 1px solid var(--border); background: var(--surface);
      color: var(--text); font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .wk-title { font-family: var(--font-display); font-size: 12px; letter-spacing: 3px; color: var(--muted); text-align: center; }
    .wk-name { font-family: var(--font-display); font-size: 12px; letter-spacing: 2px; color: var(--accent); }
    .week-tabs-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; padding-bottom: 10px; }
    .week-tabs-wrap::-webkit-scrollbar { display: none; }
    .week-tabs { display: flex; gap: 6px; width: max-content; }
    .week-tab {
      padding: 5px 12px; border-radius: 100px; border: 1px solid var(--border);
      background: transparent; color: var(--muted); font-family: var(--font-display);
      font-size: 12px; letter-spacing: 1.5px; cursor: pointer; position: relative;
    }
    .week-tab.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 700; }
    .week-tab .pdot { position: absolute; top: -3px; right: -3px; width: 7px; height: 7px; border-radius: 50%; border: 1px solid var(--bg); }
    .phase-lbl { font-family: var(--font-display); font-size: 10px; letter-spacing: 3px; color: var(--muted); padding: 3px 0 8px; }
    .ex-list { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; padding: 0 18px 100px; }
    .ex-card {
      background: var(--surface); border-radius: 12px; padding: 14px;
      margin-bottom: 8px; border: 1px solid var(--border);
    }
    .ex-card.has-data { border-color: var(--accent); }
    .ex-type-badge { display: inline-block; font-size: 10px; letter-spacing: 2px; padding: 2px 7px; border-radius: 4px; margin-bottom: 8px; font-family: var(--font-display); }
    .ex-name { font-family: var(--font-display); font-size: 15px; font-weight: 700; margin-bottom: 4px; }
    .ex-scheme { font-size: 11px; color: var(--muted); margin-bottom: 10px; font-family: var(--font-display); letter-spacing: 1px; }
    .input-row { display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 7px; }
    .input-group label { display: block; font-size: 10px; letter-spacing: 2px; color: var(--muted); margin-bottom: 4px; font-family: var(--font-display); }
    .input-group input {
      width: 100%; background: var(--surface2); border: 1px solid var(--border);
      border-radius: 7px; padding: 9px 8px; color: var(--text);
      font-family: var(--font-body); font-size: 14px; text-align: center;
      outline: none; transition: border-color 0.15s; -webkit-appearance: none;
    }
    .input-group input:focus { border-color: var(--accent); }
    .input-group input::placeholder { color: var(--muted); font-size: 12px; }
    .input-group.note input { text-align: left; font-size: 11px; }
    .pr-row { display: flex; justify-content: space-between; align-items: center; margin-top: 9px; padding-top: 9px; border-top: 1px solid var(--border); }
    .pr-lbl { font-size: 9px; letter-spacing: 2px; color: var(--muted); font-family: var(--font-display); }
    .pr-val { font-family: var(--font-display); font-size: 13px; font-weight: 700; color: #FFD166; }
    .bottom-save { position: fixed; bottom: calc(var(--nav-h) + var(--safe-bottom)); left: 0; right: 0; padding: 10px 18px; background: linear-gradient(to top, var(--bg) 60%, transparent); }
    .btn-primary {
      width: 100%; padding: 14px; background: var(--accent); border: none;
      border-radius: 12px; color: #fff; font-family: var(--font-display);
      font-size: 14px; font-weight: 700; letter-spacing: 2px; cursor: pointer;
    }
    .btn-primary:active { opacity: 0.8; }

    /* PR SCREEN */
    .pr-screen { padding: calc(var(--safe-top) + 16px) 18px 20px; }
    .pr-hdr { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
    .pr-hdr-title { font-family: var(--font-display); font-size: 28px; font-weight: 900; }
    .pr-hdr-title span { color: #FFD166; }
    .pr-sec-lbl { font-family: var(--font-display); font-size: 10px; letter-spacing: 3px; color: var(--muted); margin: 16px 0 8px; }
    .pr-item { background: var(--surface); border-radius: 10px; padding: 12px 14px; margin-bottom: 7px; border: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
    .pr-item-name { font-size: 13px; font-weight: 500; }
    .pr-item-week { font-size: 10px; color: var(--muted); margin-top: 2px; font-family: var(--font-display); letter-spacing: 1px; }
    .pr-item-weight { font-family: var(--font-display); font-size: 20px; font-weight: 900; color: #FFD166; }

    /* OVERLOAD SCREEN */
    .ol-screen { padding: calc(var(--safe-top) + 16px) 18px 20px; }
    .ol-title { font-family: var(--font-display); font-size: 28px; font-weight: 900; margin-bottom: 4px; }
    .ol-title span { color: var(--d1); }
    .ol-sub { font-size: 12px; color: var(--muted); margin-bottom: 20px; }
    .phase-card { border-radius: 12px; padding: 14px; margin-bottom: 8px; border-left: 4px solid var(--pc); background: var(--surface); border-top: 1px solid var(--border); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .phase-card-hdr { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
    .phase-card-name { font-family: var(--font-display); font-size: 18px; font-weight: 700; }
    .phase-card-wks { font-family: var(--font-display); font-size: 10px; letter-spacing: 2px; background: var(--surface2); padding: 3px 9px; border-radius: 100px; color: var(--muted); }
    .phase-card-action { font-size: 12px; color: var(--text); opacity: 0.85; margin-bottom: 3px; }
    .phase-card-goal { font-size: 11px; color: var(--muted); }
    .rules-card { background: var(--surface); border-radius: 12px; padding: 14px; margin-top: 18px; border: 1px solid var(--border); }
    .rules-title { font-family: var(--font-display); font-size: 14px; font-weight: 700; letter-spacing: 1px; margin-bottom: 10px; color: var(--d1); }
    .rule-item { display: flex; gap: 9px; margin-bottom: 9px; font-size: 12px; color: #ccc; line-height: 1.5; }
    .rule-num { font-family: var(--font-display); color: var(--d1); font-weight: 700; font-size: 15px; flex-shrink: 0; }

    /* ══════════════════════════════════════════
       MEAL SECTION
    ══════════════════════════════════════════ */
    #meal { overflow-y: auto; -webkit-overflow-scrolling: touch; }
    #meal::-webkit-scrollbar { display: none; }

    .meal-header { padding: calc(var(--safe-top) + 16px) 16px 12px; border-bottom: 1px solid var(--border); }
    .meal-eyebrow { font-size: 9px; color: var(--gold-dim); font-family: monospace; letter-spacing: 3px; margin-bottom: 4px; }
    .meal-title { font-family: var(--font-display); font-size: 24px; font-weight: 700; }
    .meal-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .meal-stats { display: flex; gap: 7px; margin-top: 10px; flex-wrap: wrap; }
    .meal-stat { background: var(--surface); border: 1px solid var(--border); border-radius: 7px; padding: 7px 10px; flex: 1 1 70px; }
    .meal-stat-val { font-size: 13px; font-family: monospace; }
    .meal-stat-lbl { font-size: 8px; color: var(--muted); font-family: monospace; margin-top: 2px; letter-spacing: 1px; }

    .meal-tabs { display: flex; border-bottom: 1px solid var(--border); }
    .meal-tab {
      flex: 1; padding: 10px 0; background: none; border: none; cursor: pointer;
      border-bottom: 2px solid transparent; color: var(--muted);
      font-family: monospace; font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    }
    .meal-tab.active { border-bottom-color: var(--gold); color: var(--gold); }

    .day-tabs { display: flex; overflow-x: auto; gap: 6px; padding: 10px 14px; border-bottom: 1px solid var(--border); -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .day-tabs::-webkit-scrollbar { display: none; }
    .day-tab {
      flex: 0 0 auto; padding: 6px 12px; border-radius: 6px;
      border: 1px solid var(--border); background: var(--surface);
      font-family: monospace; font-size: 10px; cursor: pointer; color: var(--muted);
    }
    .day-tab.active { border-color: var(--gold); background: #1e1a10; color: var(--gold); }
    .day-tab.rest { color: var(--blue); }

    .meal-content { padding: 12px 14px 100px; }
    .meal-day-title { font-size: 12px; color: var(--gold); font-family: monospace; margin-bottom: 2px; }
    .meal-day-focus { font-size: 11px; color: var(--muted); margin-bottom: 8px; }
    .macro-row { display: flex; gap: 8px; align-items: center; margin-bottom: 14px; }
    .macro-bar { flex: 1; height: 4px; background: #1e1e1e; border-radius: 3px; overflow: hidden; }
    .macro-fill { height: 100%; border-radius: 3px; transition: width 0.4s; }

    .meal-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 9px; overflow: hidden; }
    .meal-card-hdr { display: flex; justify-content: space-between; align-items: center; padding: 12px 14px; cursor: pointer; }
    .meal-card-label { font-size: 10px; color: var(--gold); font-family: monospace; letter-spacing: 2px; }
    .meal-card-time { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .meal-card-nums { text-align: right; }
    .meal-card-p { font-size: 11px; color: var(--green); font-family: monospace; }
    .meal-card-k { font-size: 11px; color: var(--gold); font-family: monospace; }
    .meal-card-body { padding: 0 14px 12px; border-top: 1px solid var(--border); }
    .food-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 1px solid #181818; }
    .food-name { font-size: 12px; color: var(--text); }
    .food-meta { display: flex; gap: 9px; align-items: center; flex-shrink: 0; }
    .food-amt { font-size: 10px; color: var(--muted); font-family: monospace; }
    .food-p { font-size: 10px; color: var(--green); font-family: monospace; min-width: 26px; text-align: right; }
    .meal-note { margin-top: 9px; font-size: 11px; color: var(--muted); line-height: 1.7; border-top: 1px solid #181818; padding-top: 9px; }

    .shake-card { background: #0d1812; border: 1px solid #1a3025; border-radius: 10px; padding: 12px 14px; margin-bottom: 9px; }
    .shake-label { font-size: 10px; color: var(--green); font-family: monospace; letter-spacing: 2px; }
    .shake-time { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .shake-desc { font-size: 12px; color: var(--text); margin-top: 4px; }
    .shake-nums { text-align: right; }
    .shake-p { font-size: 14px; color: var(--green); font-family: monospace; }
    .shake-k { font-size: 11px; color: var(--muted); font-family: monospace; }

    .timing-card { background: #111; border: 1px solid var(--border); border-radius: 8px; padding: 11px 13px; margin-top: 4px; }
    .timing-lbl { font-size: 9px; color: var(--gold-dim); font-family: monospace; letter-spacing: 2px; margin-bottom: 7px; }
    .timing-text { font-size: 11px; color: var(--muted); line-height: 1.8; }
    .timing-text b { color: var(--text); }

    /* Shopping */
    .shopping-content { padding: 14px 14px 100px; }
    .shop-eyebrow { font-size: 9px; color: var(--muted); font-family: monospace; letter-spacing: 2px; margin-bottom: 12px; }
    .shop-cat { font-size: 9px; color: var(--gold); font-family: monospace; letter-spacing: 2px; padding-bottom: 5px; border-bottom: 1px solid var(--border); margin-bottom: 7px; margin-top: 16px; }
    .shop-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 6px 0; border-bottom: 1px solid #181818; }
    .shop-name { font-size: 12px; color: var(--text); flex: 1; padding-right: 8px; }
    .shop-store { font-size: 10px; color: var(--muted); font-family: monospace; margin-top: 2px; }
    .shop-cost { font-size: 11px; color: var(--green); font-family: monospace; white-space: nowrap; }
    .budget-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 13px; margin-top: 16px; }
    .budget-lbl { font-size: 9px; color: var(--gold-dim); font-family: monospace; letter-spacing: 2px; margin-bottom: 9px; }
    .budget-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #1c1c1c; }
    .budget-row:last-child { border-bottom: none; }

    /* Notes */
    .notes-content { padding: 14px 14px 100px; }
    .notes-eyebrow { font-size: 9px; color: var(--muted); font-family: monospace; letter-spacing: 2px; margin-bottom: 12px; }
    .note-item { display: flex; gap: 10px; padding: 12px 0; border-bottom: 1px solid #181818; }
    .note-bar { width: 3px; border-radius: 2px; flex-shrink: 0; min-height: 36px; }
    .note-title { font-size: 11px; font-family: monospace; margin-bottom: 4px; }
    .note-body { font-size: 12px; color: var(--muted); line-height: 1.7; }
    .checkin-card { background: #0d1812; border: 1px solid #1a3025; border-radius: 8px; padding: 13px; margin-top: 14px; }
    .checkin-lbl { font-size: 9px; color: var(--green); font-family: monospace; letter-spacing: 2px; margin-bottom: 9px; }
    .checkin-text { font-size: 12px; color: var(--muted); line-height: 1.8; }

    /* TOAST */
    .toast { position: fixed; bottom: calc(var(--nav-h) + var(--safe-bottom) + 70px); left: 50%; transform: translateX(-50%) translateY(16px); background: #fff; color: #000; padding: 9px 18px; border-radius: 100px; font-family: var(--font-display); font-size: 12px; letter-spacing: 1px; opacity: 0; transition: all 0.3s; pointer-events: none; z-index: 999; white-space: nowrap; }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* scrollbar hide */
    .ex-list::-webkit-scrollbar, #lift::-webkit-scrollbar, .ol-screen::-webkit-scrollbar, .pr-screen::-webkit-scrollbar { display: none; }
  </style>
</head>
<body>

<!-- ══ LIFT SECTION ══ -->
<div class="app-section active" id="lift">

  <!-- HOME -->
  <div class="lift-screen active" id="ls-home">
    <div class="lift-home" style="overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;">
      <div class="lift-eyebrow">TRAINING LOG</div>
      <div class="lift-title">SMITH<br/><span>LIFTS</span></div>
      <div class="lift-sub">4-Day Concurrent DUP · Athletic Lean 175</div>
      <div class="cycle-badge">
        <div class="cycle-dot"></div>
        <div class="cycle-text" id="cycle-label">CYCLE #1 · 8 WEEKS</div>
      </div>
      <div class="day-grid" id="day-grid"></div>
      <div class="lift-footer">
        <button class="btn-ghost" onclick="newCycle()">NEW CYCLE</button>
        <button class="btn-ghost" onclick="showLift('ls-prs')">VIEW PRs</button>
        <button class="btn-ghost" onclick="showLift('ls-overload')">8WK PLAN</button>
      </div>
    </div>
  </div>

  <!-- WORKOUT -->
  <div class="lift-screen" id="ls-workout" style="display:none;flex-direction:column;height:100%;">
    <div class="workout-header">
      <div class="workout-topbar">
        <button class="btn-back" onclick="showLift('ls-home')">←</button>
        <div style="text-align:center">
          <div class="wk-title" id="wk-day-title"></div>
          <div class="wk-name" id="wk-day-name"></div>
        </div>
        <div style="width:34px;"></div>
      </div>
      <div class="week-tabs-wrap"><div class="week-tabs" id="week-tabs"></div></div>
      <div class="phase-lbl" id="phase-lbl"></div>
    </div>
    <div class="ex-list" id="ex-list"></div>
    <div class="bottom-save">
      <button class="btn-primary" id="save-btn" onclick="saveWorkout()">SAVE WORKOUT</button>
    </div>
  </div>

  <!-- PRs -->
  <div class="lift-screen" id="ls-prs" style="display:none;overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;">
    <div class="pr-screen">
      <div class="pr-hdr">
        <button class="btn-back" onclick="showLift('ls-home')">←</button>
        <div class="pr-hdr-title">PERSONAL <span>RECORDS</span></div>
      </div>
      <div id="pr-content"></div>
    </div>
  </div>

  <!-- OVERLOAD -->
  <div class="lift-screen" id="ls-overload" style="display:none;overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;">
    <div class="ol-screen">
      <button class="btn-back" onclick="showLift('ls-home')" style="margin-bottom:14px;">←</button>
      <div class="ol-title">8-WEEK <span>PLAN</span></div>
      <div class="ol-sub">Progressive overload structure · Follow precisely</div>
      <div class="phase-card" style="--pc:#3A86FF"><div class="phase-card-hdr"><div class="phase-card-name">ACCUMULATION</div><div class="phase-card-wks">WK 1–2</div></div><div class="phase-card-action">Execute as programmed</div><div class="phase-card-goal">Goal: Build work capacity and baselines</div></div>
      <div class="phase-card" style="--pc:#E63946"><div class="phase-card-hdr"><div class="phase-card-name">INTENSIFICATION</div><div class="phase-card-wks">WK 3–4</div></div><div class="phase-card-action">Add 1 set to all compound lifts</div><div class="phase-card-goal">Goal: Increase total volume on key movements</div></div>
      <div class="phase-card" style="--pc:#9B5DE5"><div class="phase-card-hdr"><div class="phase-card-name">OVERLOAD</div><div class="phase-card-wks">WK 5–6</div></div><div class="phase-card-action">+5–10 lbs on compounds, drop 1 rep</div><div class="phase-card-goal">Goal: Maximum strength stimulus</div></div>
      <div class="phase-card" style="--pc:#06D6A0"><div class="phase-card-hdr"><div class="phase-card-name">DELOAD</div><div class="phase-card-wks">WK 7</div></div><div class="phase-card-action">Cut volume 40%, keep weight</div><div class="phase-card-goal">Goal: Recovery and CNS reset</div></div>
      <div class="phase-card" style="--pc:#FFD166"><div class="phase-card-hdr"><div class="phase-card-name">RESTART</div><div class="phase-card-wks">WK 8</div></div><div class="phase-card-action">Week 1 structure, heavier baseline</div><div class="phase-card-goal">Goal: Begin new cycle at higher level</div></div>
      <div class="rules-card">
        <div class="rules-title">NON-NEGOTIABLE RULES</div>
        <div class="rule-item"><div class="rule-num">1</div><div>Add weight ONLY when every prescribed rep is completed with clean form across all sets.</div></div>
        <div class="rule-item"><div class="rule-num">2</div><div>If reps drop more than 2 between sets — rest too short OR weight too heavy. Adjust both.</div></div>
        <div class="rule-item"><div class="rule-num">3</div><div>Heavy compounds: 3 min rest. Unilateral/dynamic: 90s. Accessories: 60–90s.</div></div>
        <div class="rule-item"><div class="rule-num">4</div><div>Nordic Curls: 3 sets Day 1, 2 sets Day 3. Don't increase until Week 4–5.</div></div>
        <div class="rule-item"><div class="rule-num">5</div><div>Jump Squats: 30–50% of squat weight only. Power training, not a max lift.</div></div>
      </div>
    </div>
  </div>
</div>

<!-- ══ MEAL SECTION ══ -->
<div class="app-section" id="meal">
  <div class="meal-header">
    <div class="meal-eyebrow">RECOMP PROTOCOL V3</div>
    <div class="meal-title">Lean Mass Meal Plan</div>
    <div class="meal-sub">5'8" · 175 lbs · 2 meals + shake · IF 12PM+</div>
    <div class="meal-stats">
      <div class="meal-stat"><div class="meal-stat-val" style="color:var(--green)">~185g</div><div class="meal-stat-lbl">DAILY PROTEIN</div></div>
      <div class="meal-stat"><div class="meal-stat-val" style="color:var(--gold)">~2,500</div><div class="meal-stat-lbl">AVG CALORIES</div></div>
      <div class="meal-stat"><div class="meal-stat-val" style="color:var(--text)">$38–44</div><div class="meal-stat-lbl">FOOD / WK</div></div>
      <div class="meal-stat"><div class="meal-stat-val" style="color:var(--blue)">~$32</div><div class="meal-stat-lbl">PROTEIN / MO</div></div>
    </div>
  </div>

  <div class="meal-tabs">
    <button class="meal-tab active" onclick="setMealTab('meals',this)">Meals</button>
    <button class="meal-tab" onclick="setMealTab('shopping',this)">Shopping</button>
    <button class="meal-tab" onclick="setMealTab('notes',this)">Notes</button>
  </div>

  <!-- MEALS TAB -->
  <div id="mt-meals" style="display:flex;flex-direction:column;flex:1;overflow:hidden;">
    <div class="day-tabs" id="day-tabs"></div>
    <div class="meal-content" id="meal-content" style="overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;"></div>
  </div>

  <!-- SHOPPING TAB -->
  <div id="mt-shopping" style="display:none;overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;">
    <div class="shopping-content" id="shopping-content"></div>
  </div>

  <!-- NOTES TAB -->
  <div id="mt-notes" style="display:none;overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;">
    <div class="notes-content" id="notes-content"></div>
  </div>
</div>

<!-- ══ BOTTOM NAV ══ -->
<div class="main-nav">
  <div class="main-nav-item active" onclick="switchApp('lift',this)">
    <div class="main-nav-icon">🏋️</div>
    <div class="main-nav-label">LIFT</div>
  </div>
  <div class="main-nav-item" onclick="switchApp('meal',this)">
    <div class="main-nav-icon">🍗</div>
    <div class="main-nav-label">MEALS</div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════════
//  APP NAV
// ═══════════════════════════════════════════
function switchApp(id, el) {
  document.querySelectorAll('.app-section').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.main-nav-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
}

// ═══════════════════════════════════════════
//  LIFT DATA
// ═══════════════════════════════════════════
const LIFT_DAYS = [
  { id:'day1', label:'DAY 1', title:'Lower Body', sub:'Strength Focus', day:'Monday', color:'#E63946',
    exercises:[
      {name:'BB Squats',type:'Bilateral',scheme:'4 × 5,5,8,8'},
      {name:'Split Squats',type:'Unilateral',scheme:'3 × 8 ea.'},
      {name:'1-Leg RDL',type:'Unilateral',scheme:'3 × 8 ea.'},
      {name:'Jump Squats',type:'Dynamic',scheme:'3 × 8'},
      {name:'DB Lateral Goblet Squats',type:'Unilateral',scheme:'3 × 12 ea.'},
      {name:'Nordic Curl',type:'Unilateral',scheme:'3 × 6–8'},
      {name:'Calf Raises',type:'Bilateral',scheme:'3 × 15'},
    ]},
  { id:'day2', label:'DAY 2', title:'Upper Body', sub:'Strength Focus', day:'Wednesday', color:'#3A86FF',
    exercises:[
      {name:'Heavy DB Bench Press',type:'Bilateral',scheme:'4 × 5,5,8,8'},
      {name:'Barbell Row',type:'Bilateral',scheme:'3 × 8'},
      {name:'Single-Arm DB Row',type:'Unilateral',scheme:'3 × 8 ea.'},
      {name:'Single-Arm DB Press',type:'Unilateral',scheme:'3 × 8 ea.'},
      {name:'Incline DB Bench',type:'Bilateral',scheme:'3 × 10'},
      {name:'Lat Pull Down',type:'Bilateral',scheme:'3 × 10'},
    ]},
  { id:'day3', label:'DAY 3', title:'Lower Body', sub:'Hypertrophy Focus', day:'Thursday', color:'#06D6A0',
    exercises:[
      {name:'BB Squats (Volume)',type:'Bilateral',scheme:'3 × 12'},
      {name:'DB Lunges (Walking)',type:'Unilateral',scheme:'3 × 10 ea.'},
      {name:'Lateral Band Walk + Reverse Lunge',type:'Dynamic',scheme:'3 × 12 ea.'},
      {name:'DB Lateral Goblet Squats',type:'Unilateral',scheme:'3 × 12 ea.'},
      {name:'Nordic Curl',type:'Unilateral',scheme:'2 × 6–8'},
      {name:'Calf Raises',type:'Bilateral',scheme:'3 × 20'},
    ]},
  { id:'day4', label:'DAY 4', title:'Upper Body', sub:'Hypertrophy Focus', day:'Saturday', color:'#9B5DE5',
    exercises:[
      {name:'DB Fly / Squeeze Press',type:'Superset',scheme:'3 × 12'},
      {name:'Seated Rows',type:'Bilateral',scheme:'3 × 12'},
      {name:'Straight Arm Pull Down',type:'Bilateral',scheme:'3 × 12'},
      {name:'Single-Arm Cable Fly',type:'Unilateral',scheme:'3 × 12 ea.'},
      {name:'Seated Lateral Raises',type:'Bilateral',scheme:'3 × 12'},
      {name:'Rear Delt Fly',type:'Bilateral',scheme:'3 × 12'},
      {name:'EZ Bar / Hammer Curl',type:'Superset',scheme:'3 × 12'},
    ]},
];
const WEEKS = ['Wk 1','Wk 2','Wk 3','Wk 4','Wk 5','Wk 6','Wk 7','Wk 8'];
const PHASES = {'Wk 1':'Accumulation','Wk 2':'Accumulation','Wk 3':'Intensification','Wk 4':'Intensification','Wk 5':'Overload','Wk 6':'Overload','Wk 7':'Deload','Wk 8':'Restart'};
const PCOLORS = {Accumulation:'#3A86FF',Intensification:'#E63946',Overload:'#9B5DE5',Deload:'#06D6A0',Restart:'#FFD166'};
const TCOLORS = {Bilateral:'#3A86FF33',Unilateral:'#06D6A033',Dynamic:'#E6394633',Superset:'#9B5DE533'};
const TTEXT  = {Bilateral:'#3A86FF',Unilateral:'#06D6A0',Dynamic:'#E63946',Superset:'#9B5DE5'};

function loadState() { try { return JSON.parse(localStorage.getItem('smithLifts')||'{}'); } catch { return {}; } }
function saveStateLS() { localStorage.setItem('smithLifts', JSON.stringify(LS)); }
let LS = loadState();
if (!LS.cycle) LS.cycle = 1;
if (!LS.data)  LS.data  = {};
if (!LS.week)  LS.week  = 'Wk 1';
let currentDay = null;

function getEntry(dayId, exName, week) {
  if (!LS.data[dayId]) LS.data[dayId] = {};
  if (!LS.data[dayId][exName]) LS.data[dayId][exName] = {};
  if (!LS.data[dayId][exName][week]) LS.data[dayId][exName][week] = {weight:'',reps:'',note:''};
  return LS.data[dayId][exName][week];
}
function dayPct(dayId) {
  const d = LIFT_DAYS.find(x => x.id === dayId); if (!d) return 0;
  let f=0,t=0;
  d.exercises.forEach(ex => WEEKS.forEach(wk => { t++; const e=getEntry(dayId,ex.name,wk); if(e.weight||e.reps) f++; }));
  return t>0?Math.round((f/t)*100):0;
}
function getPR(dayId,exName) {
  let max=0,wk='';
  WEEKS.forEach(w => { const v=parseFloat(getEntry(dayId,exName,w).weight); if(!isNaN(v)&&v>max){max=v;wk=w;} });
  return max>0?{weight:max,week:wk}:null;
}
function getGain(dayId,exName) {
  const ws=WEEKS.map(w=>parseFloat(getEntry(dayId,exName,w).weight)).filter(v=>!isNaN(v)&&v>0);
  return ws.length>=2?ws[ws.length-1]-ws[0]:null;
}

// Lift screen nav
function showLift(id) {
  document.querySelectorAll('.lift-screen').forEach(s => { s.classList.remove('active'); s.style.display='none'; });
  const el = document.getElementById(id);
  el.style.display = 'flex';
  el.classList.add('active');
  if (id==='ls-home') renderLiftHome();
  if (id==='ls-prs')  renderPRs();
}

function renderLiftHome() {
  document.getElementById('cycle-label').textContent = `CYCLE #${LS.cycle} · 8 WEEKS`;
  const grid = document.getElementById('day-grid');
  grid.innerHTML = '';
  LIFT_DAYS.forEach(d => {
    const pct = dayPct(d.id);
    const card = document.createElement('div');
    card.className = 'day-card';
    card.style.setProperty('--accent', d.color);
    card.onclick = () => openDay(d.id);
    card.innerHTML = `<div class="day-card-num">${d.label.split(' ')[1]}</div>
      <div class="day-card-label">${d.label}</div>
      <div class="day-card-title">${d.title}<br/><span style="color:${d.color};font-size:13px">${d.sub}</span></div>
      <div class="day-card-day">${d.day}</div>
      <div class="day-card-bar"><div class="day-card-fill" style="width:${pct}%;background:${d.color}"></div></div>
      <div class="day-card-pct">${pct}% logged</div>`;
    grid.appendChild(card);
  });
}

function openDay(dayId) {
  currentDay = LIFT_DAYS.find(d => d.id === dayId);
  showLift('ls-workout');
  renderWorkout();
}

function renderWorkout() {
  const d = currentDay;
  document.getElementById('wk-day-title').textContent = `${d.label} · ${d.title.toUpperCase()}`;
  document.getElementById('wk-day-name').textContent = d.day.toUpperCase();
  document.getElementById('save-btn').style.background = d.color;
  document.documentElement.style.setProperty('--accent', d.color);

  const tabsEl = document.getElementById('week-tabs');
  tabsEl.innerHTML = '';
  WEEKS.forEach(wk => {
    const phase = PHASES[wk];
    const btn = document.createElement('button');
    btn.className = 'week-tab' + (LS.week===wk?' active':'');
    btn.innerHTML = `${wk}<span class="pdot" style="background:${PCOLORS[phase]}"></span>`;
    btn.onclick = () => { LS.week=wk; saveStateLS(); renderWorkout(); };
    tabsEl.appendChild(btn);
  });
  document.getElementById('phase-lbl').textContent = `${PHASES[LS.week].toUpperCase()} PHASE`;

  const list = document.getElementById('ex-list');
  list.innerHTML = '';
  d.exercises.forEach(ex => {
    const entry = getEntry(d.id, ex.name, LS.week);
    const pr = getPR(d.id, ex.name);
    const gain = getGain(d.id, ex.name);
    const hasData = !!(entry.weight||entry.reps);
    const card = document.createElement('div');
    card.className = 'ex-card'+(hasData?' has-data':'');
    card.innerHTML = `
      <div class="ex-type-badge" style="background:${TCOLORS[ex.type]||'#ffffff11'};color:${TTEXT[ex.type]||'#aaa'}">${ex.type.toUpperCase()}</div>
      <div class="ex-name">${ex.name}</div>
      <div class="ex-scheme">${ex.scheme}</div>
      <div class="input-row">
        <div class="input-group"><label>WEIGHT</label><input type="number" inputmode="decimal" placeholder="lbs" value="${entry.weight}" onchange="updateEntry('${d.id}','${ex.name}','weight',this.value)"/></div>
        <div class="input-group"><label>REPS</label><input type="number" inputmode="numeric" placeholder="reps" value="${entry.reps}" onchange="updateEntry('${d.id}','${ex.name}','reps',this.value)"/></div>
        <div class="input-group note"><label>NOTE</label><input type="text" placeholder="feel / form" value="${entry.note||''}" onchange="updateEntry('${d.id}','${ex.name}','note',this.value)"/></div>
      </div>
      ${(pr||gain!==null)?`<div class="pr-row"><div><div class="pr-lbl">PERSONAL RECORD</div><div class="pr-val">${pr?`${pr.weight} LBS · ${pr.week}`:'—'}</div></div>${gain!==null?`<span style="font-family:var(--font-display);font-size:13px;font-weight:700;color:${gain>=0?'#06D6A0':'#E63946'}">${gain>=0?'+':''}${gain} LBS</span>`:''}</div>`:''}
    `;
    list.appendChild(card);
  });
}

function updateEntry(dayId,exName,field,value) {
  getEntry(dayId,exName,LS.week)[field]=value;
}
function saveWorkout() { saveStateLS(); toast('SAVED ✓'); renderLiftHome(); }
function renderPRs() {
  const el = document.getElementById('pr-content'); el.innerHTML='';
  LIFT_DAYS.forEach(d => {
    const lbl=document.createElement('div'); lbl.className='pr-sec-lbl'; lbl.textContent=`${d.label} — ${d.title.toUpperCase()}`; el.appendChild(lbl);
    d.exercises.forEach(ex => {
      const pr=getPR(d.id,ex.name);
      const item=document.createElement('div'); item.className='pr-item';
      item.innerHTML=`<div><div class="pr-item-name">${ex.name}</div><div class="pr-item-week">${pr?pr.week:'NO DATA YET'}</div></div><div class="pr-item-weight">${pr?`${pr.weight} LBS`:'—'}</div>`;
      el.appendChild(item);
    });
  });
}
function newCycle() {
  if (!confirm(`Start Cycle #${LS.cycle+1}? Clears all logged data.`)) return;
  LS.cycle++; LS.data={}; LS.week='Wk 1'; saveStateLS(); renderLiftHome(); toast(`CYCLE #${LS.cycle} STARTED`);
}

// ═══════════════════════════════════════════
//  MEAL DATA
// ═══════════════════════════════════════════
const DAYS = [
  {label:"MON",title:"Monday",focus:"Push — Chest / Shoulders / Triceps",type:"train",
   meal1:{time:"12:00 PM",label:"Meal 1",items:[{food:"Chicken thighs, boneless skin-on",amt:"8 oz",p:46,k:370},{food:"Frozen broccoli",amt:"1½ cups",p:5,k:55},{food:"White rice (cooked)",amt:"1½ cups",p:5,k:300},{food:"Olive oil",amt:"1 tsp",p:0,k:40}],note:"Season chicken with garlic powder, paprika, salt. Roast or pan-sear. Steam broccoli."},
   meal2:{time:"6:30 PM — Post-Training",label:"Meal 2",items:[{food:"Chicken breast",amt:"8 oz",p:50,k:280},{food:"Fettuccine (cooked)",amt:"1½ cups",p:10,k:330},{food:"Frozen zucchini",amt:"1 cup",p:2,k:25},{food:"Heavy cream",amt:"3 tbsp",p:1,k:150},{food:"Butter",amt:"1 tbsp",p:0,k:100}],note:"Sear chicken breast, slice thin. Sauté zucchini in butter, add heavy cream, reduce, toss with pasta and chicken."},
   shake:{time:"Immediately Post-Workout",scoops:2,p:50,k:250}},
  {label:"TUE",title:"Tuesday",focus:"Pull — Back / Biceps",type:"train",
   meal1:{time:"12:00 PM",label:"Meal 1",items:[{food:"80/20 Ground beef",amt:"8 oz",p:46,k:580},{food:"String beans",amt:"1½ cups",p:4,k:50},{food:"Frozen sweet potato (cooked)",amt:"1 cup",p:4,k:180},{food:"Butter",amt:"1 tbsp",p:0,k:100}],note:"Season beef with garlic powder, onion powder, salt. Cook sweet potato in oven or microwave."},
   meal2:{time:"6:30 PM — Post-Training",label:"Meal 2",items:[{food:"Chicken thighs, boneless skin-on",amt:"10 oz",p:57,k:460},{food:"Asparagus",amt:"1 cup",p:3,k:30},{food:"White rice (cooked)",amt:"1½ cups",p:5,k:300},{food:"Olive oil",amt:"1 tsp",p:0,k:40}],note:"Pan-sear chicken thighs skin-side down first. Roast asparagus with olive oil and salt at 400°F for 12 min."},
   shake:{time:"Immediately Post-Workout",scoops:2,p:50,k:250}},
  {label:"WED",title:"Wednesday",focus:"Legs — Quads / Hamstrings / Glutes",type:"train",
   meal1:{time:"12:00 PM",label:"Meal 1",items:[{food:"80/20 Ground beef",amt:"8 oz",p:46,k:580},{food:"Frozen broccoli",amt:"1½ cups",p:5,k:55},{food:"White rice (cooked)",amt:"1½ cups",p:5,k:300},{food:"Olive oil",amt:"1 tsp",p:0,k:40}],note:"Brown beef, season with garlic powder and paprika. Steam broccoli. Serve over rice."},
   meal2:{time:"7:00 PM — Post-Training",label:"Meal 2",items:[{food:"Chicken breast",amt:"8 oz",p:50,k:280},{food:"Fettuccine (cooked)",amt:"2 cups",p:14,k:440},{food:"Cherry tomatoes (halved)",amt:"½ cup",p:1,k:25},{food:"Heavy cream",amt:"3 tbsp",p:1,k:150},{food:"Butter",amt:"1 tbsp",p:0,k:100}],note:"Blister cherry tomatoes in butter until they burst, add cream, reduce into sauce. Slice chicken over pasta."},
   shake:{time:"Immediately Post-Workout",scoops:2,p:50,k:250}},
  {label:"THU",title:"Thursday",focus:"Rest / Active Recovery",type:"rest",
   meal1:{time:"12:00 PM",label:"Meal 1",items:[{food:"Chicken thighs, boneless skin-on",amt:"6 oz",p:35,k:280},{food:"Frozen butternut squash (cooked)",amt:"1 cup",p:2,k:80},{food:"White rice (cooked)",amt:"1 cup",p:4,k:200},{food:"Butter",amt:"1 tbsp",p:0,k:100}],note:"Rest day — portions slightly reduced. Roast squash with butter and a pinch of salt."},
   meal2:{time:"6:00 PM",label:"Meal 2",items:[{food:"80/20 Ground beef",amt:"8 oz",p:46,k:580},{food:"Zucchini",amt:"1 cup",p:2,k:25},{food:"Frozen sweet potato (cooked)",amt:"1 cup",p:4,k:180},{food:"Olive oil",amt:"1 tsp",p:0,k:40}],note:"Sauté zucchini in olive oil until golden. Brown beef separately, combine. Serve alongside sweet potato."},
   shake:{time:"Afternoon — between meals",scoops:1,p:25,k:125}},
  {label:"FRI",title:"Friday",focus:"Push — Chest / Shoulders / Triceps",type:"train",
   meal1:{time:"12:00 PM",label:"Meal 1",items:[{food:"80/20 Ground beef",amt:"8 oz",p:46,k:580},{food:"String beans",amt:"1½ cups",p:4,k:50},{food:"White rice (cooked)",amt:"1½ cups",p:5,k:300},{food:"Olive oil",amt:"1 tsp",p:0,k:40}],note:"Brown beef with garlic powder and onion powder. Blanch or sauté string beans in olive oil with salt."},
   meal2:{time:"6:30 PM — Post-Training",label:"Meal 2",items:[{food:"Chicken breast",amt:"10 oz",p:62,k:350},{food:"Fettuccine (cooked)",amt:"1½ cups",p:10,k:330},{food:"Asparagus",amt:"1 cup",p:3,k:30},{food:"Heavy cream",amt:"3 tbsp",p:1,k:150},{food:"Butter",amt:"1 tbsp",p:0,k:100}],note:"Blanch asparagus 3 min, sauté in butter, add cream and reduce. Slice seared chicken over pasta and sauce."},
   shake:{time:"Immediately Post-Workout",scoops:2,p:50,k:250}},
  {label:"SAT",title:"Saturday",focus:"Pull — Back / Biceps",type:"train",
   meal1:{time:"12:00 PM",label:"Meal 1",items:[{food:"Chicken thighs, boneless skin-on",amt:"8 oz",p:46,k:370},{food:"Frozen broccoli",amt:"1½ cups",p:5,k:55},{food:"Frozen sweet potato (cooked)",amt:"1 cup",p:4,k:180},{food:"Olive oil",amt:"1 tsp",p:0,k:40}],note:"Roast chicken thighs at 400°F skin-side up for 25–30 min. Steam broccoli. Microwave sweet potato 5–6 min."},
   meal2:{time:"6:30 PM — Post-Training",label:"Meal 2",items:[{food:"80/20 Ground beef",amt:"10 oz",p:57,k:725},{food:"Frozen butternut squash (cooked)",amt:"1 cup",p:2,k:80},{food:"White rice (cooked)",amt:"1½ cups",p:5,k:300},{food:"Butter",amt:"1 tbsp",p:0,k:100}],note:"Brown beef, season well. Roast or microwave squash with butter. Serve over rice."},
   shake:{time:"Immediately Post-Workout",scoops:2,p:50,k:250}},
  {label:"SUN",title:"Sunday",focus:"Legs / Core",type:"train",
   meal1:{time:"12:00 PM",label:"Meal 1",items:[{food:"Chicken thighs, boneless skin-on",amt:"8 oz",p:46,k:370},{food:"Asparagus",amt:"1 cup",p:3,k:30},{food:"White rice (cooked)",amt:"1½ cups",p:5,k:300},{food:"Olive oil",amt:"1 tsp",p:0,k:40}],note:"Pan-sear chicken thighs. Roast asparagus with olive oil and garlic powder at 400°F."},
   meal2:{time:"7:00 PM — Post-Training",label:"Meal 2",items:[{food:"Chicken breast",amt:"8 oz",p:50,k:280},{food:"Fettuccine (cooked)",amt:"2 cups",p:14,k:440},{food:"Frozen zucchini",amt:"1 cup",p:2,k:25},{food:"Heavy cream",amt:"3 tbsp",p:1,k:150},{food:"Butter",amt:"1 tbsp",p:0,k:100}],note:"Sauté zucchini in butter until golden, add cream, reduce 2–3 min. Slice chicken over pasta and sauce."},
   shake:{time:"Immediately Post-Workout",scoops:2,p:50,k:250}},
];

const SHOPPING = [
  {cat:"Protein",items:[{name:"Chicken thighs, boneless skin-on (5 lb family pack)",cost:"$8–10",store:"Aldi"},{name:"Chicken breast (2 lb)",cost:"$6–8",store:"Aldi"},{name:"80/20 Ground beef (3 lbs)",cost:"$9–11",store:"Aldi"},{name:"Nutricost Whey Concentrate 5lb",cost:"$40–45",store:"Amazon"}]},
  {cat:"Carbs",items:[{name:"White rice (5 lb bag)",cost:"$3–4",store:"Aldi"},{name:"Fettuccine pasta (2 lb box)",cost:"$2–3",store:"Aldi"},{name:"Frozen organic sweet potato (1–2 lb bag)",cost:"$3–4",store:"Aldi"}]},
  {cat:"Vegetables",items:[{name:"Frozen broccoli (2 lb bag)",cost:"$2.50",store:"Aldi"},{name:"Frozen zucchini (1 lb bag)",cost:"$2–3",store:"Aldi"},{name:"Frozen butternut squash (1 lb bag)",cost:"$2.50",store:"Aldi"},{name:"Fresh asparagus (1 bunch)",cost:"$2.50–3",store:"Aldi"},{name:"Fresh string beans (1 lb)",cost:"$2–2.50",store:"Aldi"},{name:"Cherry tomatoes (1 pint)",cost:"$2.50–3",store:"Aldi"}]},
  {cat:"Dairy / Fats",items:[{name:"Heavy cream (1 pint)",cost:"$3–4",store:"Aldi"},{name:"Butter (1 lb)",cost:"$3–4",store:"Aldi"},{name:"Olive oil (16 oz)",cost:"$3–4",store:"Aldi"}]},
  {cat:"Pantry",items:[{name:"Garlic powder, paprika, onion powder, salt, black pepper",cost:"$4–6 one-time",store:"Aldi"},{name:"Soy sauce or hot sauce",cost:"$2",store:"Aldi"}]},
];

const NOTES = [
  {title:"Protein target — met",body:"Food alone averages 175–185g protein daily. The shake adds 50g on training days and 25g on rest days. You're in range.",color:"#52b788"},
  {title:"Heavy cream — accounted for",body:"3 tbsp per fettuccine meal adds ~150 calories and 1g protein. Don't eyeball it — use your food scale consistently.",color:"#c8a96e"},
  {title:"Fettuccine appears 4x this week",body:"Mon, Wed, Fri, Sun. Always chicken breast, always a different vegetable. Rotate: zucchini → cherry tomatoes → asparagus → zucchini.",color:"#74b3ce"},
  {title:"Frozen vs. fresh vegetables",body:"Frozen zucchini, broccoli, butternut squash, and sweet potato are fine nutritionally. Fresh asparagus, string beans, and cherry tomatoes are better fresh.",color:"#c8a96e"},
  {title:"Sweet potato as carb swap",body:"Swap rice for frozen organic sweet potato on any meal without pasta. Microwave 5–6 min, no prep needed. Good on rest days — slower digesting carb.",color:"#52b788"},
  {title:"Shift timing",body:"7AM–3:30PM: Meal 1 at 12PM → train 4–5PM → shake → Meal 2 at 6:30PM. 12:30PM–9PM: Train 9–11AM → shake → Meal 1 at 12:30PM → Meal 2 post-shift ~9:30PM.",color:"#74b3ce"},
  {title:"Eating out — 1x/week",body:"Built into the budget. Choose protein-forward: burger bowl, grilled chicken plate, steak tacos. Avoid heavy cream or pasta dishes when eating out.",color:"#6b6b6b"},
  {title:"Rest day calories drop intentionally",body:"Thursday sits ~300 calories below training days. One shake scoop instead of two. Don't add food to compensate.",color:"#6b6b6b"},
];

let mealDayIdx = 0;
let openMeals = {meal1: true, meal2: true};

function setMealTab(tab, el) {
  ['meals','shopping','notes'].forEach(t => document.getElementById(`mt-${t}`).style.display='none');
  document.getElementById(`mt-${tab}`).style.display='flex';
  document.querySelectorAll('.meal-tab').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  if (tab==='shopping') renderShopping();
  if (tab==='notes') renderNotes();
}

function renderDayTabs() {
  const el = document.getElementById('day-tabs'); el.innerHTML='';
  DAYS.forEach((d,i) => {
    const btn=document.createElement('button');
    btn.className='day-tab'+(i===mealDayIdx?' active':'')+(d.type==='rest'?' rest':'');
    btn.textContent=d.label+(d.type==='rest'?' ●':'');
    btn.onclick=()=>{ mealDayIdx=i; renderDayTabs(); renderMealContent(); };
    el.appendChild(btn);
  });
}

function renderMealContent() {
  const day=DAYS[mealDayIdx];
  const m1p=day.meal1.items.reduce((s,i)=>s+i.p,0);
  const m2p=day.meal2.items.reduce((s,i)=>s+i.p,0);
  const totalP=m1p+m2p+day.shake.p;
  const m1k=day.meal1.items.reduce((s,i)=>s+i.k,0);
  const m2k=day.meal2.items.reduce((s,i)=>s+i.k,0);
  const totalK=m1k+m2k+day.shake.k;
  const pct=Math.min((totalP/210)*100,100);

  const el=document.getElementById('meal-content');
  el.innerHTML=`
    <div class="meal-day-title">${day.title}</div>
    <div class="meal-day-focus">${day.focus}</div>
    <div class="macro-row">
      <span style="font-size:10px;color:var(--green);font-family:monospace;white-space:nowrap">${totalP}g protein</span>
      <div class="macro-bar"><div class="macro-fill" style="width:${pct}%;background:var(--green)"></div></div>
      <span style="font-size:10px;color:var(--gold);font-family:monospace;white-space:nowrap">${totalK} kcal</span>
    </div>
    ${mealCardHTML(day.meal1,'meal1')}
    ${shakeHTML(day.shake)}
    ${mealCardHTML(day.meal2,'meal2')}
    <div class="timing-card">
      <div class="timing-lbl">SHIFT TIMING</div>
      <div class="timing-text"><b>7AM–3:30PM:</b> Meal 1 @ 12PM → Train 4–5PM → Shake → Meal 2 @ 6:30PM<br/><b>12:30–9PM:</b> Train 9–11AM → Shake → Meal 1 @ 12:30PM → Meal 2 post-shift</div>
    </div>
  `;
  // attach toggles
  el.querySelectorAll('.meal-card-hdr').forEach(hdr => {
    hdr.onclick = () => {
      const key = hdr.dataset.key;
      openMeals[key] = !openMeals[key];
      const body = document.getElementById(`mb-${key}`);
      body.style.display = openMeals[key] ? 'block' : 'none';
    };
  });
}

function mealCardHTML(meal, key) {
  const tp=meal.items.reduce((s,i)=>s+i.p,0);
  const tk=meal.items.reduce((s,i)=>s+i.k,0);
  const open=openMeals[key]!==false;
  return `<div class="meal-card">
    <div class="meal-card-hdr" data-key="${key}">
      <div><div class="meal-card-label">${meal.label}</div><div class="meal-card-time">${meal.time}</div></div>
      <div style="display:flex;gap:10px;align-items:center">
        <div class="meal-card-nums"><div class="meal-card-p">${tp}g</div><div class="meal-card-k">${tk} kcal</div></div>
        <span style="font-size:13px;color:var(--muted)">${open?'▴':'▾'}</span>
      </div>
    </div>
    <div id="mb-${key}" class="meal-card-body" style="display:${open?'block':'none'}">
      ${meal.items.map(item=>`<div class="food-row"><span class="food-name">${item.food}</span><div class="food-meta"><span class="food-amt">${item.amt}</span><span class="food-p">${item.p}g</span></div></div>`).join('')}
      ${meal.note?`<div class="meal-note">🍳 ${meal.note}</div>`:''}
    </div>
  </div>`;
}

function shakeHTML(shake) {
  return `<div class="shake-card">
    <div style="display:flex;justify-content:space-between;align-items:center">
      <div>
        <div class="shake-label">WHEY SHAKE — ${shake.scoops} SCOOP${shake.scoops>1?'S':''}</div>
        <div class="shake-time">${shake.time}</div>
        <div class="shake-desc">${shake.scoops} scoop${shake.scoops>1?'s':''} Nutricost Whey + 14 oz cold water</div>
      </div>
      <div class="shake-nums"><div class="shake-p">${shake.p}g</div><div class="shake-k">${shake.k} kcal</div></div>
    </div>
  </div>`;
}

function renderShopping() {
  const el=document.getElementById('shopping-content');
  el.innerHTML=`<div class="shop-eyebrow">ALDI + AMAZON WEEKLY LIST</div>`;
  SHOPPING.forEach(cat => {
    el.innerHTML+=`<div class="shop-cat">${cat.cat}</div>`;
    cat.items.forEach(item => {
      el.innerHTML+=`<div class="shop-item"><div><div class="shop-name">${item.name}</div><div class="shop-store">${item.store}</div></div><span class="shop-cost">${item.cost}</span></div>`;
    });
  });
  el.innerHTML+=`<div class="budget-card">
    <div class="budget-lbl">MONTHLY BUDGET</div>
    <div class="budget-row"><span style="font-size:12px;color:var(--muted)">Food (weekly $38–44 × 4)</span><span style="font-size:12px;color:var(--green);font-family:monospace">$152–176</span></div>
    <div class="budget-row"><span style="font-size:12px;color:var(--muted)">Nutricost Whey 5lb (avg/mo)</span><span style="font-size:12px;color:var(--green);font-family:monospace">~$32</span></div>
    <div class="budget-row"><span style="font-size:12px;color:var(--text);font-weight:600">TOTAL</span><span style="font-size:12px;color:var(--gold);font-family:monospace;font-weight:700">$184–208</span></div>
  </div>`;
}

function renderNotes() {
  const el=document.getElementById('notes-content');
  el.innerHTML=`<div class="notes-eyebrow">PROTOCOL NOTES</div>`;
  NOTES.forEach(n => {
    el.innerHTML+=`<div class="note-item"><div class="note-bar" style="background:${n.color}"></div><div><div class="note-title" style="color:${n.color}">${n.title}</div><div class="note-body">${n.body}</div></div></div>`;
  });
  el.innerHTML+=`<div class="checkin-card">
    <div class="checkin-lbl">WEEKLY CHECK-IN</div>
    <div class="checkin-text">📅 <b style="color:var(--text)">Every Sunday AM</b> — weigh in, same time, after bathroom<br/>📸 <b style="color:var(--text)">1st of each month</b> — progress photo, same lighting, same pose<br/>📊 <b style="color:var(--text)">4-week rule</b> — no change in weight or mirror? Adjust calories ±150</div>
  </div>`;
}

// ═══════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════
function toast(msg) {
  const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2000);
}

// ═══════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════
renderLiftHome();
renderDayTabs();
renderMealContent();
</script>
</body>
</html>
